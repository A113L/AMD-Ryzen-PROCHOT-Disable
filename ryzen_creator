def vid_to_voltage(vid: int) -> float:
    return 1.55 - vid * 0.00625

def calculate_entropy(length, pool_size):
    if pool_size <= 1 or length <= 0:
        return 0.0
    return length * math.log2(pool_size)

def get_cpu_freqs():
    try:
        out = subprocess.run(["grep", "MHz", "/proc/cpuinfo"], capture_output=True, text=True)
        lines = out.stdout.strip().splitlines()
        vals = sorted(set(float(line.split(":")[1].strip()) for line in lines))
        return vals
    except Exception:
        return []

def get_temps():
    temps = {}
    try:
        out = subprocess.run(["sensors"], capture_output=True, text=True)
        for line in out.stdout.splitlines():
            if "Tctl" in line or "Tdie" in line or "CPU" in line:
                parts = line.split(":")
                if len(parts) == 2:
                    label = parts[0].strip()
                    val = parts[1].strip().split()[0]
                    temps[label] = val
    except Exception:
        pass
    return temps

def run_stress(timeout_sec=10):
    if not shutil.which("stress-ng"):
        return None, "stress-ng not installed"
    try:
        cpus = os.cpu_count() or 4
        proc = subprocess.Popen(
            ["stress-ng", "--cpu", str(cpus), "--timeout", f"{timeout_sec}s"],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE
        )
        return proc, None
    except Exception as e:
        return None, str(e)

