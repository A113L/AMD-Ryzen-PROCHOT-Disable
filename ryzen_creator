        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        w = max(1080, min(1280, sw - 80))
        h = max(720, min(860, sh - 100))
        x = (sw - w) // 2
        y = max(0, (sh - h) // 2 - 20)
