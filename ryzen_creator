    def refresh_service_status(self):
        try:
            out = subprocess.run(["systemctl", "status", "disable_prochot_mode.service", "--no-pager"],
                                 capture_output=True, text=True)
            text = out.stdout + out.stderr
            active = "active" in out.stdout.lower() and "running" in out.stdout.lower()
            loaded = "loaded" in out.stdout.lower()
            if active:
                self.svc_status_label.config(text="Status: ACTIVE (Running)", fg=self.theme["success"])
            elif loaded:
                self.svc_status_label.config(text="Status: Installed (Not running)", fg=self.theme["warning"])
            else:
                self.svc_status_label.config(text="Status: Not installed", fg=self.theme["text_secondary"])
        except Exception as e:
            text = f"Could not query systemd: {e}"
            self.svc_status_label.config(text="Status: Unknown", fg=self.theme["danger"])
        self.svc_output.config(state=tk.NORMAL)
        self.svc_output.delete(1.0, tk.END)
        self.svc_output.insert(tk.END, text)
        self.svc_output.config(state=tk.DISABLED)

    def install_unit(self):
        unit_path = "/etc/systemd/system/disable_prochot_mode.service"
        if not messagebox.askyesno("Install Unit",
                                   f"Write systemd unit to:\n{unit_path}\n\nRequires root."):
            return
        try:
            with open(unit_path, "w") as f:
                f.write(SYSTEMD_UNIT)
            subprocess.run(["systemctl", "daemon-reload"], check=True, capture_output=True)
            messagebox.showinfo("Installed", f"Unit installed to {unit_path}")
            self.refresh_service_status()
        except Exception as e:
            messagebox.showerror("Error", str(e))

    def run_systemctl(self, action):
        try:
            out = subprocess.run(["systemctl", action, "disable_prochot_mode.service"],
                                 capture_output=True, text=True)
            self.svc_output.config(state=tk.NORMAL)
            self.svc_output.delete(1.0, tk.END)
            self.svc_output.insert(tk.END, out.stdout + out.stderr)
            self.svc_output.config(state=tk.DISABLED)
            self.refresh_service_status()
        except Exception as e:
            messagebox.showerror("Error", str(e))

    # ------------------------------------------------------------------
    # Preflight
    # ------------------------------------------------------------------
    def preflight(self) -> bool:
        if os.geteuid() != 0:
            messagebox.showerror("Root Required", "This application must be run as root.\n\nUse: sudo python3 ryzen_creator_gui.py")
            return False
        if not SMUController.module_loaded():
            messagebox.showerror("Module Missing", "The ryzen_smu kernel module is not loaded.\n\nRun: sudo modprobe ryzen_smu")
            return False
        return True

