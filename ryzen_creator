    def apply_profile_dialog(self):
        if not self.preflight():
            return
        freq = self.freq_var.get()
        vid = self.vid_var.get()
        volt = vid_to_voltage(vid)
        prochot = self.prochot_var.get()
        msg = (f"Apply profile?\n\n"
               f"Frequency: {freq} MHz\n"
               f"VID: {vid} ({volt:.4f} V)\n"
               f"PROCHOT: {'Disabled' if prochot else 'Enabled'}\n\n"
               f"PPT=1000W  TDC=114A  EDC=168A\n\n"
               f"These settings are volatile and require adequate cooling.")
        if not messagebox.askyesno("Confirm Apply", msg, icon="warning"):
            return
        self._do_apply(freq, vid, prochot)

    def _do_apply(self, freq, vid, disable_prochot):
        self.profile_status.config(text="Applying…", fg=self.theme["accent"])
        self.root.update()
        try:
            ok = SMUController.apply_profile(freq, vid, disable_prochot)
            if ok:
                self.log(f"Profile applied: {freq} MHz, VID {vid} ({vid_to_voltage(vid):.4f}V)", "OK")
                self.profile_status.config(text="Profile applied successfully.", fg=self.theme["success"])
            else:
                self.log("SMU reported failure for one or more commands.", "FAIL")
                self.profile_status.config(text="SMU command failure — check logs", fg=self.theme["danger"])
        except Exception as e:
            self.log(str(e), "ERROR")
            self.profile_status.config(text=f"Error: {e}", fg=self.theme["danger"])
            return

        # Show freqs
        freqs = get_cpu_freqs()
        if freqs:
            self.log(f"Current CPU frequencies: {freqs}", "INFO")

        if not self.skip_test_var.get():
            self.log("Starting 10s stress test…", "INFO")
            self.root.update()
            proc, err = run_stress(10)
            if proc:
                try:
                    proc.wait(timeout=12)
                    self.log("Stress test completed.", "OK")
                except subprocess.TimeoutExpired:
                    proc.kill()
                    self.log("Stress test timed out.", "WARN")
            elif err:
                self.log(f"Stress test skipped: {err}", "WARN")
            freqs = get_cpu_freqs()
            if freqs:
                self.log(f"Frequencies under load: {freqs}", "INFO")

