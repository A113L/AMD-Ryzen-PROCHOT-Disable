    def start_sequence(self):
        if not self.preflight():
            return
        if self.seq_running:
            return
        start = self.seq_start_freq.get()
        stop = self.seq_stop_freq.get()
        step = self.seq_step_freq.get()
        vstart = self.seq_vid_start.get()
        vstep = self.seq_vid_step.get()
        stress_sec = self.seq_stress_sec.get()

        if start > stop:
            messagebox.showerror("Error", "Start frequency must be <= stop frequency.")
            return

        self.seq_running = True
        self.seq_run_btn.config(state=tk.DISABLED)
        self.seq_stop_btn.config(state=tk.NORMAL)
        self.seq_status.config(text="Running…", fg=self.theme["accent"])
        self.seq_text.config(state=tk.NORMAL)
        self.seq_text.delete(1.0, tk.END)
        self.seq_text.config(state=tk.DISABLED)
        self.log("=== Sequence started ===", "INFO")

        self.seq_thread = threading.Thread(target=self._sequence_worker,
                                           args=(start, stop, step, vstart, vstep, stress_sec),
                                           daemon=True)
        self.seq_thread.start()

    def _sequence_worker(self, start, stop, step, vstart, vstep, stress_sec):
        try:
            freq = start
            vid = vstart
            step_num = 1
            while freq <= stop and self.seq_running:
                if vid < MIN_VID:
                    self.log(f"VID {vid} below floor {MIN_VID} — stopping.", "WARN")
                    break
                self.log(f"--- Step {step_num}: {freq} MHz, VID {vid} ({vid_to_voltage(vid):.4f}V) ---", "INFO")
                try:
                    ok = SMUController.apply_profile(freq, vid, True)
                    if not ok:
                        self.log("SMU command failure — aborting sequence.", "FAIL")
                        break
                except Exception as e:
                    self.log(f"SMU error: {e} — aborting.", "ERROR")
                    break

                time.sleep(1)
                freqs = get_cpu_freqs()
                if freqs:
                    self.log(f"Frequencies: {freqs}", "INFO")

                # Stress
                self.log(f"Stress test ({stress_sec}s)…", "INFO")
                proc, err = run_stress(stress_sec)
                if proc:
                    try:
                        rc = proc.wait(timeout=stress_sec + 5)
                        if rc != 0:
                            self.log(f"Stress test failed (exit {rc}) — stopping sequence.", "FAIL")
                            break
                        self.log("Stress test passed.", "OK")
                    except subprocess.TimeoutExpired:
                        proc.kill()
                        self.log("Stress test timed out — stopping sequence.", "WARN")
                        break
                elif err:
                    self.log(f"No stress-ng: {err}", "WARN")

                temps = get_temps()
                if temps:
                    self.log(f"Temps: {temps}", "INFO")

                freq += step
                vid -= vstep
                step_num += 1

            if self.seq_running:
                self.log("=== Sequence finished ===", "OK")
                self.seq_status.config(text="Finished", fg=self.theme["success"])
            else:
                self.log("=== Sequence stopped by user ===", "WARN")
                self.seq_status.config(text="Stopped", fg=self.theme["warning"])
        finally:
            self.seq_running = False
            self.seq_run_btn.config(state=tk.NORMAL)
            self.seq_stop_btn.config(state=tk.DISABLED)

    def stop_sequence(self):
        self.seq_running = False
        self.seq_status.config(text="Stopping…", fg=self.theme["warning"])

