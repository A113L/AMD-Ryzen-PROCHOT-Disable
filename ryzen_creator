# ---------------------------------------------------------------------------
# SMU driver interface
# ---------------------------------------------------------------------------
DRV = "/sys/kernel/ryzen_smu_drv"

class SMUController:
    @staticmethod
    def module_loaded() -> bool:
        return os.path.isdir(DRV)

    @staticmethod
    def send_cmd(arg_dec: int, cmd_hex: str) -> bool:
        try:
            arg_bytes = arg_dec.to_bytes(24, "little")
            with open(f"{DRV}/smu_args", "wb") as f:
                f.write(arg_bytes)
            with open(f"{DRV}/rsmu_cmd", "wb") as f:
                f.write(bytes.fromhex(cmd_hex))
            with open(f"{DRV}/rsmu_cmd", "rb") as f:
                status = binascii.hexlify(f.read()).decode()
            return status.startswith("01000000")
        except Exception as e:
            raise RuntimeError(f"SMU command 0x{cmd_hex} failed: {e}")

    @classmethod
    def apply_profile(cls, freq: int, vid: int, disable_prochot: bool = True):
        ok = True
        ok &= cls.send_cmd(16777216, "5b")  # DisableOverclocking (cleanup)
        ok &= cls.send_cmd(0, "5a")          # EnableOverclocking
        ok &= cls.send_cmd(1000000, "53")    # PPT 1000W
        ok &= cls.send_cmd(114000, "54")     # TDC 114A
        ok &= cls.send_cmd(168000, "55")     # EDC 168A
        ok &= cls.send_cmd(vid, "61")        # VID
        ok &= cls.send_cmd(freq, "5c")       # All-core freq
        if disable_prochot:
            ok &= cls.send_cmd(16777216, "5a")  # PROCHOT off
        return ok

    @classmethod
    def reset_to_stock(cls):
        return cls.send_cmd(16777216, "5b")  # DisableOverclocking

