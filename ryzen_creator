    def _configure_styles(self):
        style = ttk.Style()
        try:
            style.theme_use("clam")
        except tk.TclError:
            pass
        style.configure("Accent.Horizontal.TProgressbar",
                        background=self.theme["accent"], troughcolor=self.theme["trough"],
                        borderwidth=0, lightcolor=self.theme["accent"], darkcolor=self.theme["accent"])

    def make_button(self, parent, text, kind="neutral", **kwargs):
        palette = {
            "accent": (self.theme["accent"], self.theme["accent_hover"], "#ffffff"),
            "success": (self.theme["success"], self.theme["success_hover"], "#ffffff"),
            "danger": (self.theme["danger"], self.theme["danger_hover"], "#ffffff"),
            "neutral": (self.theme["button_bg"], self.theme["input_bg"], "#ffffff"),
        }[kind]
        bg, hover, fg = palette
        if kind == "neutral" and self.theme_name == "light":
            bg, hover = "#4b5563", "#374151"
        btn = tk.Button(parent, text=text, font=(self.font_family, 11, "bold"),
                        bd=0, padx=18, pady=9, bg=bg, fg=fg,
                        activebackground=hover, activeforeground=fg,
                        cursor="hand2", relief=tk.FLAT, **kwargs)
        def on_enter(_e):
            if str(btn["state"]) != tk.DISABLED:
                btn.config(bg=hover)
        def on_leave(_e):
            if str(btn["state"]) != tk.DISABLED:
                btn.config(bg=bg)
        btn.bind("<Enter>", on_enter)
        btn.bind("<Leave>", on_leave)
        btn._base_bg = bg
        return btn

    def create_card(self, parent, title=None, subtitle=None):
        card = tk.Frame(parent, bg=self.theme["surface"], bd=0,
                        highlightthickness=1, highlightbackground=self.theme["border"])
        if title:
            head = tk.Frame(card, bg=self.theme["surface"])
            head.pack(fill=tk.X, padx=16, pady=(13, 8))
            tk.Label(head, text=title, font=(self.font_family, 12, "bold"),
                     bg=self.theme["surface"], fg=self.theme["text"]).pack(anchor=tk.W)
            if subtitle:
                tk.Label(head, text=subtitle, font=(self.font_family, 9),
                         bg=self.theme["surface"], fg=self.theme["text_secondary"]).pack(anchor=tk.W, pady=(2, 0))
            tk.Frame(card, bg=self.theme["border"], height=1).pack(fill=tk.X, padx=16, pady=(0, 10))
        return card

    def switch_tab(self, tab):
        self.active_tab = tab
        self._paint_tabs()
        self.show_tab(tab)
        if tab == "monitor":
            self.start_monitor()
        else:
            self.stop_monitor()

    def show_tab(self, tab):
        for key, frame in [("profile", self.profile_frame), ("sequence", self.sequence_frame),
                           ("monitor", self.monitor_frame), ("service", self.service_frame)]:
            if key == tab:
                frame.lift()
            else:
                frame.lower()

    def _paint_tabs(self):
        for name, btn in self.tab_buttons.items():
            if name == self.active_tab:
                btn.config(bg=self.theme["accent"], fg=self.theme["accent_fg"],
                           activebackground=self.theme["accent_hover"], activeforeground=self.theme["accent_fg"])
            else:
                btn.config(bg=self.theme["surface"], fg=self.theme["text_secondary"],
                           activebackground=self.theme["surface_alt"], activeforeground=self.theme["text"])

    def switch_theme(self):
        # Cancel monitor before destroying widgets
        if self.monitor_after:
            try:
                self.root.after_cancel(self.monitor_after)
            except Exception:
                pass
            self.monitor_after = None
        # Remove old tk variable traces so they don't fire on destroyed widgets
        for var, tid in self._trace_ids:
            try:
                var.trace_remove("write", tid)
            except Exception:
                pass
        self._trace_ids.clear()
        new_theme = "light" if self.theme_name == "dark" else "dark"
        self.theme_name = new_theme
        self.theme = THEMES[new_theme]
        self.root.configure(bg=self.theme["bg"])
        self.main_frame.destroy()
        self.main_frame = tk.Frame(self.root, bg=self.theme["bg"])
        self.main_frame.grid(row=0, column=0, sticky="nsew")
        self.build_ui()

